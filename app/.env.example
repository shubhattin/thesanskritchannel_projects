PG_DATABASE_URL="postgresql://username:password@host:port/database"
PUBLIC_BETTER_AUTH_URL="http://localhost:your-port"
# Current Site URL
VITE_SITE_URL="http://localhost:your-site-port"
# Public marketing / reader site — used for “open on main site” links in unauthorized layout screens
VITE_MAIN_SITE_URL="https://example.com"

UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"
QSTASH_URL="https://qstash.example.com"
QSTASH_TOKEN="exampleQStashApiToken"
QSTASH_CURRENT_SIGNING_KEY="sig_exampleCurrentSigningKey"
QSTASH_NEXT_SIGNING_KEY="sig_exampleNextSigningKey"

TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"

TRIGGER_SECRET_KEY="your-trigger-secret-key"
PUBLIC_LOCAL_CONFIG=true
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENAI_API_KEY="your-openai-api-key"

# Posthog (Optional)
VITE_POSTHOG_KEY="example-public-posthog-key"
VITE_POSTHOG_URL="https://us.i.posthog.com"

# AWS
AWS_ACCESS_KEY_ID="EXAMPLEACCESSKEY123456"
AWS_REGION="us-west-2"
AWS_S3_FILES_BUCKET_NAME="my-example-s3-bucket"
