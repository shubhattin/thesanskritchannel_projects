---
import NotFoundPage from '$components/NotFoundPage.astro';
import RootLayout from '$components/RootLayout.astro';
import { LiveEntryNotFoundError } from 'astro/content/runtime';
import { getLiveEntry, render } from 'astro:content';

const slug = Astro.params.slug;
const { entry: rawEntry, error } = await getLiveEntry('lekha', slug ?? '');

if (error) {
  if (LiveEntryNotFoundError.is(error)) {
    Astro.response.status = 404;
  } else {
    throw error;
  }
}

let entry = rawEntry;
if (entry?.data.draft === true) {
  Astro.response.status = 404;
  entry = void 0;
}

const rendered = entry
  ? await render({ ...entry, collection: 'lekha' } as Parameters<typeof render>[0])
  : null;
const Content = rendered?.Content;
---

{
  entry && Content ? (
    <RootLayout title={`${entry.data.title} — Lekha`} description={entry.data.description}>
      <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
        <header class="mb-10 border-b border-border pb-8">
          <p class="text-sm font-medium tracking-wide text-primary uppercase">Lekha</p>
          <h1 class="mt-2 text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
            {entry.data.title}
          </h1>
          {entry.data.description && (
            <p class="mt-4 text-lg text-muted-foreground">{entry.data.description}</p>
          )}
          <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
            <time datetime={entry.data.pubDate.toISOString()}>
              Published{' '}
              {entry.data.pubDate.toLocaleDateString('en-IN', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
            {entry.data.updatedDate && (
              <time datetime={entry.data.updatedDate.toISOString()}>
                Updated{' '}
                {entry.data.updatedDate.toLocaleDateString('en-IN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
            )}
          </div>
        </header>
        <div class="lekha-markdown prose prose-neutral max-w-none dark:prose-invert prose-headings:font-semibold prose-a:text-primary prose-headings:text-foreground">
          <Content />
        </div>
        <p class="mt-12 text-sm text-muted-foreground">
          <a href="/lekha" class="text-primary hover:underline">
            ← All posts
          </a>
        </p>
      </article>
    </RootLayout>
  ) : (
    <NotFoundPage />
  )
}
