---
import NotFoundPage from '$components/NotFoundPage.astro';
import TextRoutePage from '$components/TextRoutePage.astro';
import { get_text_data_func } from '$app/server/text_loader';
import { get_child_route_items, resolve_text_route } from '~/utils/text-routes';
import { db, redis } from '../../db/site_db';
import { waitUntil } from '@vercel/functions';

export const prerender = false;

const resolved = await resolve_text_route(Astro.params.key ?? '', []);
if (!resolved) {
  Astro.response.status = 404;
}

if (resolved?.redirect_to) {
  return Astro.redirect(resolved.redirect_to, 301);
}
const text =
  resolved && resolved.node.info.type === 'shloka'
    ? await get_text_data_func(resolved.project_key, resolved.path_params, {
        defer: waitUntil,
        db: db,
        redis: redis
      })
    : null;
const child_items = resolved
  ? get_child_route_items(resolved.project_key, resolved.map, resolved.path_params)
  : [];
---

{
  resolved ? (
    <TextRoutePage resolved={resolved} child_items={child_items} text={text} />
  ) : (
    <NotFoundPage />
  )
}
