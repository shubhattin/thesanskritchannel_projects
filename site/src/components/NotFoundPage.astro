---
import RootLayout from '$components/RootLayout.astro';
---

<RootLayout title="Not Found" description="The requested page could not be found." index={false}>
  <main
    class="mx-auto flex min-h-screen w-full max-w-3xl flex-col items-start justify-center gap-6 px-4 py-10 sm:px-6"
  >
    <p class="text-sm tracking-[0.2em] text-muted-foreground uppercase">404</p>
    <div class="space-y-3">
      <h1 class="text-4xl font-semibold tracking-tight">Page not found</h1>
      <p class="text-base text-muted-foreground">
        The route does not match a known text or section yet.
      </p>
    </div>
    <a class="rounded-md border px-4 py-2 hover:bg-accent hover:text-accent-foreground" href="/">
      Return home
    </a>
  </main>
</RootLayout>
