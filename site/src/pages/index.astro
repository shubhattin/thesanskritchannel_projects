---
import RootLayout from '$components/RootLayout.astro';
import { PROJECT_LIST } from '../../../app/src/state/project_list';
import Youtube from '@lucide/svelte/icons/youtube';
import ArrowRight from '@lucide/svelte/icons/arrow-right';
import ExternalLink from '@lucide/svelte/icons/external-link';
import Heart from '@lucide/svelte/icons/heart';
import Icon from '~/components/utils/Icon.astro';
import { db } from '~/db/site_db';
import { get_site_lekha_list_func } from '$app/server/cached_loader';
import { redis } from '~/db/site_db';
import { waitUntil } from '@vercel/functions';

// TODO: shall use the cached loader later
const latest_lekhas = await get_site_lekha_list_func({ db, redis, defer: waitUntil });
---

<RootLayout
  title="The Sanskrit Channel — Explore Authentic Sanskrit Literature"
  description="Discover ancient Sanskrit texts, learn Indian scripts, and explore tools for Sanskrit learning. Read Valmiki Ramayanam, Bhagavad Gita, and more in multiple scripts."
>
  <!-- Hero Section -->
  <section
    class="relative overflow-hidden border-b border-border/30 bg-linear-to-br from-background via-accent/20 to-primary/5 outline-hidden"
  >
    <!-- Decorative background pattern -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0); background-size: 40px 40px;"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:py-36">
      <div class="mx-auto max-w-3xl text-center">
        <!-- Sanskrit decorative quote -->
        <!-- <p
          class="font-devanagari mb-4 text-sm tracking-wider text-primary/60 sm:text-base"
          aria-hidden="true"
        >
          ॐ वाङ्मे मनसि प्रतिष्ठिता
        </p> -->

        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
          <span class="bg-linear-to-r from-primary to-primary/70 bg-clip-text text-transparent"
            >Explore Sanskrit</span
          >{' '}
          Literature
        </h1>

        <p
          class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg"
        >
          Explore authentic Sanskrit literature through a modern reading experience. Read texts in
          multiple Indian scripts, use powerful learning tools, and join a community dedicated to
          preserving ancient wisdom.
        </p>

        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="#texts"
            class="inline-flex h-11 items-center justify-center rounded-lg bg-primary px-8 text-sm font-semibold text-primary-foreground shadow-md transition-transform duration-150 hover:scale-[1.02] hover:shadow-lg focus-visible:ring-2 focus-visible:ring-ring/50 focus-visible:outline-none"
          >
            Explore Texts
          </a>
          <a
            href="https://www.youtube.com/@TheSanskritChannel"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 items-center justify-center gap-2 rounded-lg border border-border px-8 text-sm font-semibold text-foreground transition-colors duration-150 hover:bg-accent hover:text-accent-foreground focus-visible:ring-2 focus-visible:ring-ring/50 focus-visible:outline-none"
          >
            <Icon icon={Youtube} class="size-6 text-red-500" />
            Watch on YouTube
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Texts Section -->
  <section
    id="texts"
    class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20"
    style="scroll-margin-top: 4rem;"
  >
    <div class="mb-10 text-center">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Sacred Texts</h2>
      <p class="mx-auto mt-3 max-w-xl text-sm text-muted-foreground sm:text-base">
        Read classical Sanskrit texts in a clean, distraction-free interface. Switch between
        multiple Indian scripts effortlessly.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        PROJECT_LIST.map((project, index) => (
          <a
            href={`/${project.key}`}
            class:list={[
              'card-hover-glow group relative rounded-xl border bg-card p-6 transition-colors duration-150 hover:border-primary/30',
              `animate-fade-in-up stagger-${index + 1}`
            ]}
          >
            <div class="space-y-2">
              <p class="font-devanagari text-xl font-medium text-foreground transition-colors duration-150 group-hover:text-primary">
                {project.name_dev}
              </p>
              <p class="text-sm text-muted-foreground">{project.name}</p>
            </div>
            <div class="mt-4 flex items-center gap-1 text-xs font-medium text-primary/70">
              <span>Read</span>
              <Icon
                icon={ArrowRight}
                class="size-3.5 transition-transform duration-150 group-hover:translate-x-0.5"
              />
            </div>
          </a>
        ))
      }
    </div>
  </section>

  {
    latest_lekhas.length > 0 && (
      <section class="border-b border-border/30 bg-muted/20" aria-labelledby="lekha-latest-heading">
        <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-16">
          <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 id="lekha-latest-heading" class="text-2xl font-bold tracking-tight sm:text-3xl">
                Latest from Lekha
              </h2>
              <p class="mt-2 max-w-xl text-sm text-muted-foreground sm:text-base">
                Short notes and articles — read the most recent posts.
              </p>
            </div>
            <a
              href="/lekha"
              class="inline-flex shrink-0 items-center gap-1 text-sm font-semibold text-primary hover:underline"
            >
              View all
              <Icon icon={ArrowRight} class="size-4" />
            </a>
          </div>
          <ul class="flex flex-col gap-3 sm:gap-4">
            {latest_lekhas.map((post, index) => (
              <li>
                <a
                  href={`/lekha/${post.url_slug}`}
                  class:list={[
                    'card-hover-glow group block rounded-xl border border-border/60 bg-card/60 px-5 py-4 transition-colors duration-150 hover:border-primary/40 hover:bg-accent/30',
                    `animate-fade-in-up stagger-${index + 1}`
                  ]}
                >
                  <h3 class="text-lg font-semibold tracking-tight text-foreground transition-colors group-hover:text-primary">
                    {post.title}
                  </h3>
                  {post.description && (
                    <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">
                      {post.description}
                    </p>
                  )}
                  {post.published_at && (
                    <time
                      class="mt-3 block text-xs text-muted-foreground"
                      datetime={post.published_at.toISOString()}
                    >
                      {post.published_at.toLocaleDateString('en-IN', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Tools Showcase Section -->
  <section
    id="tools"
    class="border-t border-border/30 bg-muted/30"
    style="scroll-margin-top: 4rem;"
  >
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Tools for Sanskrit Learning</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm text-muted-foreground sm:text-base">
          Interactive tools designed to help you learn, practice, and experience Sanskrit in new
          ways.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <!-- Padavali -->
        <a
          href="https://krida.thesanskritchannel.org/padavali"
          target="_blank"
          rel="noopener noreferrer"
          class="card-hover-glow group animate-fade-in-up stagger-1 flex gap-4 rounded-xl border bg-card p-6 transition-colors duration-150 hover:border-primary/30"
        >
          <div class="flex size-10 shrink-0 overflow-hidden rounded-lg bg-primary/10 text-primary">
            <img
              src="/icons/apps/padavali_64.png"
              alt=""
              width="40"
              height="40"
              class="h-full w-full object-contain"
              aria-hidden="true"
            />
          </div>
          <div class="min-w-0">
            <div class="flex items-center gap-1.5">
              <h3 class="font-semibold">Padavali</h3>
              <Icon icon={ExternalLink} class="size-3.5 text-muted-foreground" />
            </div>
            <p class="mt-1 text-sm text-muted-foreground">
              Sanskrit Word Game playable in multiple Indian scripts.
            </p>
          </div>
        </a>

        <!-- Svara Darshini -->
        <a
          href="https://svara.thesanskritchannel.org/"
          target="_blank"
          rel="noopener noreferrer"
          class="card-hover-glow group animate-fade-in-up stagger-2 flex gap-4 rounded-xl border bg-card p-6 transition-colors duration-150 hover:border-primary/30"
        >
          <div class="flex size-10 shrink-0 overflow-hidden rounded-lg bg-primary/10 text-primary">
            <img
              src="/icons/apps/svara_64.png"
              alt=""
              width="40"
              height="40"
              class="h-full w-full object-contain"
              aria-hidden="true"
            />
          </div>
          <div class="min-w-0">
            <div class="flex items-center gap-1.5">
              <h3 class="font-semibold">Svara Darshini</h3>
              <Icon icon={ExternalLink} class="size-3.5 text-muted-foreground" />
            </div>
            <p class="mt-1 text-sm text-muted-foreground">
              Visualize and practice Vedic pitch levels for chanting.
            </p>
          </div>
        </a>

        <!-- Akshara -->
        <a
          href="https://akshara.thesanskritchannel.org/"
          target="_blank"
          rel="noopener noreferrer"
          class="card-hover-glow group animate-fade-in-up stagger-3 flex gap-4 rounded-xl border bg-card p-6 transition-colors duration-150 hover:border-primary/30"
        >
          <div class="flex size-10 shrink-0 overflow-hidden rounded-lg bg-primary/10 text-primary">
            <img
              src="/icons/apps/akshara_64.png"
              alt=""
              width="40"
              height="40"
              class="h-full w-full object-contain"
              aria-hidden="true"
            />
          </div>
          <div class="min-w-0">
            <div class="flex items-center gap-1.5">
              <h3 class="font-semibold">Akshara</h3>
              <Icon icon={ExternalLink} class="size-3.5 text-muted-foreground" />
            </div>
            <p class="mt-1 text-sm text-muted-foreground">
              Interactive lessons to learn, read, and write Indian scripts.
            </p>
          </div>
        </a>

        <!-- Lipi Lekhika -->
        <a
          href="https://lipilekhika.in/"
          target="_blank"
          rel="noopener noreferrer"
          class="card-hover-glow group animate-fade-in-up stagger-4 flex gap-4 rounded-xl border bg-card p-6 transition-colors duration-150 hover:border-primary/30"
        >
          <div class="flex size-10 shrink-0 overflow-hidden rounded-lg bg-primary/10 text-primary">
            <img
              src="/icons/apps/lipi.svg"
              alt=""
              width="40"
              height="40"
              class="h-full w-full object-contain"
              aria-hidden="true"
            />
          </div>
          <div class="min-w-0">
            <div class="flex items-center gap-1.5">
              <h3 class="font-semibold">Lipi Lekhika</h3>
              <Icon icon={ExternalLink} class="size-3.5 text-muted-foreground" />
            </div>
            <p class="mt-1 text-sm text-muted-foreground">
              Convert text between Indian scripts with ease.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Support CTA Section -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
    <div
      class="relative overflow-hidden rounded-2xl bg-linear-to-br from-primary/10 via-accent/30 to-primary/5 p-8 text-center sm:p-12"
    >
      <div class="relative">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Support Our Mission</h2>
        <p class="mx-auto mt-3 max-w-lg text-sm text-muted-foreground sm:text-base">
          Help us make ancient Sanskrit treasures accessible to everyone. Your support keeps this
          project alive and growing.
        </p>
        <a
          href="/support"
          class="mt-8 inline-flex h-11 items-center justify-center gap-2 rounded-lg bg-primary px-8 text-sm font-semibold text-primary-foreground shadow-md transition-transform duration-150 hover:scale-[1.02] hover:shadow-lg focus-visible:ring-2 focus-visible:ring-ring/50 focus-visible:outline-none"
        >
          <Icon icon={Heart} class="size-4" />
          Support Us
        </a>
      </div>
    </div>
  </section>
</RootLayout>
