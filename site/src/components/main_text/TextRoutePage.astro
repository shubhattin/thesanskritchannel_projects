---
import LanguageSelect from '$components/main_text/LanguageSelect.svelte';
import MainTextScriptSelector from '$components/main_text/MainTextScriptSelector.svelte';
import RootLayout from '$components/RootLayout.astro';
import type { shloka_list_type } from '$app/state/data_types';
import {
  get_display_script_from_id,
  transliterate_for_display,
  transliterate_list_for_display
} from '~/lib/main_text/script-display';
import { getFontClass } from '~/components/utils/font_list';
import type { resolved_text_route_type } from '~/utils/text-routes';

type ChildRouteItem = {
  index: number;
  href: string;
  name_dev: string;
  name_nor: string;
  is_leaf: boolean;
};

type Props = {
  resolved: resolved_text_route_type;
  child_items: ChildRouteItem[];
  text: shloka_list_type | null;
  selected_lang_id: number;
  selected_script_id: number;
  translation: Map<number, string> | null;
};

const { resolved, child_items, text, selected_lang_id, selected_script_id, translation }: Props =
  Astro.props;
const scriptFontClass =
  getFontClass(get_display_script_from_id(selected_script_id)) ?? 'font-normal';
const display_path_names = await transliterate_list_for_display(
  resolved.path_names,
  selected_script_id
);
const display_child_items = await Promise.all(
  child_items.map(async (item) => ({
    ...item,
    name_display: await transliterate_for_display(item.name_dev, selected_script_id)
  }))
);
const display_text =
  text !== null
    ? await transliterate_list_for_display(
        text.map((item) => item.text),
        selected_script_id
      )
    : [];
const current_title = resolved.path_names.at(-1) ?? resolved.project_name;
const page_title = `${current_title} | ${resolved.project_name}`;
const page_description =
  resolved.path_names.length === 0
    ? `Browse ${resolved.project_name}`
    : `Browse ${resolved.project_name} — ${resolved.path_names.join(' / ')}`;
const breadcrumb_items = display_path_names.map((name, index) => ({
  name,
  href:
    index === display_path_names.length - 1
      ? null
      : `/${resolved.project_key}/${resolved.canonical_path
          .split('/')
          .slice(2, index + 3)
          .join('/')}`,
  level_name: resolved.path_level_names[index]
}));
---

<RootLayout title={page_title} description={page_description}>
  <main class="mx-auto flex w-full max-w-5xl flex-col gap-8 px-4 py-8 sm:px-6 sm:py-10">
    <!-- Page Header -->
    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-[0.2em] text-primary/70 uppercase">
        {resolved.project_name}
      </p>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{current_title}</h1>
      {
        display_path_names.length > 0 && (
          <p class={`text-sm text-muted-foreground ${scriptFontClass}`}>
            {display_path_names.join(' / ')}
          </p>
        )
      }
    </div>

    <!-- Breadcrumb Navigation -->
    <nav
      aria-label="Breadcrumb"
      class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground"
    >
      <a
        class="inline-flex items-center gap-1 rounded-md px-2 py-1 transition-colors duration-150 hover:bg-accent hover:text-accent-foreground focus-visible:ring-2 focus-visible:ring-ring/50 focus-visible:outline-none"
        href="/"
      >
        <svg viewBox="0 0 24 24" class="size-3.5" aria-hidden="true">
          <path
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        Home
      </a>

      <!-- Separator -->
      <svg viewBox="0 0 24 24" class="size-3" aria-hidden="true">
        <path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="m9 18 6-6-6-6"></path>
      </svg>

      <a
        class="rounded-md px-2 py-1 transition-colors duration-150 hover:bg-accent hover:text-accent-foreground focus-visible:ring-2 focus-visible:ring-ring/50 focus-visible:outline-none"
        href={`/${resolved.project_key}`}
      >
        {resolved.project_name}
      </a>

      {
        breadcrumb_items.map((item) => (
          <>
            <svg viewBox="0 0 24 24" class="size-3" aria-hidden="true">
              <path
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="m9 18 6-6-6-6"
              />
            </svg>
            {item.href ? (
              <a
                class="rounded-md px-2 py-1 transition-colors duration-150 hover:bg-accent hover:text-accent-foreground focus-visible:ring-2 focus-visible:ring-ring/50 focus-visible:outline-none"
                href={item.href}
              >
                <span class="text-xs text-muted-foreground/70">{item.level_name}:</span>{' '}
                <span class={scriptFontClass}>{item.name}</span>
              </a>
            ) : (
              <span class="rounded-md px-2 py-1 font-medium text-foreground" aria-current="page">
                <span class="text-xs text-muted-foreground/70">{item.level_name}:</span>{' '}
                <span class={scriptFontClass}>{item.name}</span>
              </span>
            )}
          </>
        ))
      }
    </nav>

    {
      resolved.node.info.type === 'list' ? (
        <section class="flex flex-col gap-5">
          <MainTextScriptSelector client:load initial_script_id={selected_script_id} />
          <div class="grid gap-3">
            {display_child_items.map((item) => (
              <a
                class="card-hover-glow group flex items-center gap-4 rounded-xl border bg-card p-4 transition-colors duration-150 hover:border-primary/30"
                href={item.href}
              >
                {/* Number badge */}
                <span
                  class="flex size-8 shrink-0 items-center justify-center rounded-lg bg-muted text-xs font-semibold text-muted-foreground"
                  style="font-variant-numeric: tabular-nums;"
                >
                  {item.index}
                </span>

                {/* Text content */}
                <div class="min-w-0 flex-1 space-y-0.5">
                  <p class={`truncate text-base font-medium ${scriptFontClass}`}>
                    {item.name_display}
                  </p>
                  <p class="truncate text-sm text-muted-foreground">{item.name_nor}</p>
                </div>

                {/* Arrow / Icon */}
                <div class="shrink-0 text-muted-foreground transition-colors duration-150 group-hover:text-primary">
                  {item.is_leaf ? (
                    <svg viewBox="0 0 24 24" class="size-4" aria-hidden="true">
                      <path
                        fill="none"
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"
                      />
                    </svg>
                  ) : (
                    <svg
                      viewBox="0 0 24 24"
                      class="size-4 transition-transform duration-150 group-hover:translate-x-0.5"
                      aria-hidden="true"
                    >
                      <path
                        fill="none"
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="m9 18 6-6-6-6"
                      />
                    </svg>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      ) : (
        <section class="flex flex-col gap-5">
          {resolved.path_params.length > 0 ? (
            <a
              class="inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors duration-150 hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring/50 focus-visible:outline-none"
              href={`/${resolved.project_key}`}
            >
              <svg viewBox="0 0 24 24" class="size-3.5" aria-hidden="true">
                <path
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="m15 18-6-6 6-6"
                />
              </svg>
              Back to {resolved.project_name}
            </a>
          ) : null}

          <div class="flex flex-wrap gap-4">
            <MainTextScriptSelector client:load initial_script_id={selected_script_id} />
            <LanguageSelect client:load initial_lang_id={selected_lang_id} />
          </div>

          <div class="space-y-4">
            {(text ?? []).map((item, index) => (
              <div class="rounded-lg border bg-card/50 p-4 sm:p-5">
                <div class="flex gap-3">
                  {/* Shloka number (commented out as per request)
                  <span
                    class="mt-0.5 flex size-7 shrink-0 items-center justify-center rounded-md bg-primary/10 text-xs font-semibold text-primary"
                    style="font-variant-numeric: tabular-nums;"
                  >
                    {item.index}
                  </span>
                  */}
                  <div class="min-w-0 flex-1 space-y-2">
                    <div
                      class={`text-base leading-8 whitespace-pre-line sm:text-lg ${scriptFontClass}`}
                    >
                      {display_text[index]}
                    </div>
                    {selected_lang_id !== -1 && translation?.has(item.index) ? (
                      <div class="border-t border-border/30 pt-2 text-sm leading-7 whitespace-pre-line text-yellow-700 dark:text-yellow-400">
                        {translation.get(item.index)}
                      </div>
                    ) : null}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }
  </main>
</RootLayout>
