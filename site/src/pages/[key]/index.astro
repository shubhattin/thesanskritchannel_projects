---
import NotFoundPage from '$components/NotFoundPage.astro';
import TextRoutePage from '$components/main_text/TextRoutePage.astro';
import { CACHE } from '$app/utils/cache.server/cached_loader.server';
import {
  get_child_route_items,
  get_selected_text_levels_from_path_params,
  resolve_text_route
} from '~/utils/text-routes';
import { cache_db_options_site } from '~/db/cache_db_options';
import {
  LANG_ID_COOKIE_NAME,
  SCRIPT_ID_COOKIE_NAME,
  DEFAULT_LANG_ID,
  parse_lang_id_cookie,
  parse_script_id_cookie
} from '~/lib/cookies';

export const prerender = false;

const resolved = await resolve_text_route(Astro.params.key ?? '', []);
if (!resolved) {
  Astro.response.status = 404;
}

if (resolved?.redirect_to) {
  return Astro.redirect(resolved.redirect_to, 301);
}

const selected_lang_id = parse_lang_id_cookie(Astro.cookies.get(LANG_ID_COOKIE_NAME)?.value);
const selected_script_id = parse_script_id_cookie(Astro.cookies.get(SCRIPT_ID_COOKIE_NAME)?.value);
const available_lang_ids =
  resolved && resolved.node.info.type === 'shloka'
    ? await CACHE.available_translation_langs.get(
        { project_id: resolved.project_id, path_params: resolved.path_params },
        cache_db_options_site
      )
    : [];
const effective_lang_id = available_lang_ids.includes(selected_lang_id)
  ? selected_lang_id
  : DEFAULT_LANG_ID;
const text =
  resolved && resolved.node.info.type === 'shloka'
    ? await CACHE.text_data.get(
        { key: resolved.project_key, path_params: resolved.path_params },
        cache_db_options_site
      )
    : null;
const translation =
  resolved && resolved.node.info.type === 'shloka' && effective_lang_id !== -1
    ? await CACHE.translation.get(
        {
          project_id: resolved.project_id,
          lang_id: effective_lang_id,
          selected_text_levels: get_selected_text_levels_from_path_params(
            resolved.path_params,
            resolved.levels
          )
        },
        cache_db_options_site
      )
    : null;
const child_items = resolved
  ? get_child_route_items(resolved.project_key, resolved.map, resolved.path_params, resolved.levels)
  : [];

let media_links: Awaited<ReturnType<typeof CACHE.media_links.get>> = [];
if (resolved) {
  try {
    media_links = await CACHE.media_links.get(
      { project_id: resolved.project_id, path_params: resolved.path_params },
      cache_db_options_site
    );
  } catch {
    // Path may not exist or have no media links.
  }
}
---

{
  resolved ? (
    <TextRoutePage
      resolved={resolved}
      child_items={child_items}
      text={text}
      selected_lang_id={effective_lang_id}
      selected_script_id={selected_script_id}
      available_lang_ids={available_lang_ids}
      translation={translation}
      media_links={media_links}
    />
  ) : (
    <NotFoundPage />
  )
}
