---
import '$app/lib/carta_markdown/code/shiki-theme.css';
import LekhaCodeBlockCopy from '$components/lekha/LekhaCodeBlockCopy.svelte';
import MainTextScriptSelector from '$components/main_text/MainTextScriptSelector.svelte';
import NotFoundPage from '$components/NotFoundPage.astro';
import RootLayout from '$components/RootLayout.astro';
import { getFontClass } from '~/components/utils/font_list';
import { get_display_script_from_id } from '~/lib/main_text/script-display';
import { SCRIPT_ID_COOKIE_NAME, parse_script_id_cookie } from '~/lib/cookies';
import { LiveEntryNotFoundError } from 'astro/content/runtime';
import { getLiveEntry, render } from 'astro:content';

const selected_script_id = parse_script_id_cookie(Astro.cookies.get(SCRIPT_ID_COOKIE_NAME)?.value);

const slug = Astro.params.slug;
const { entry: rawEntry, error } = await getLiveEntry('lekha', {
  id: slug ?? '',
  scriptId: selected_script_id
});

if (error) {
  if (LiveEntryNotFoundError.is(error)) {
    Astro.response.status = 404;
  } else {
    throw error;
  }
}

let entry = rawEntry;
if (entry?.data.draft === true) {
  Astro.response.status = 404;
  entry = void 0;
}

const rendered = entry
  ? await render({ ...entry, collection: 'lekha' } as Parameters<typeof render>[0])
  : null;
const Content = rendered?.Content;

const lekha_body_font_class =
  getFontClass(get_display_script_from_id(selected_script_id)) ?? 'font-normal';
---

{
  entry && Content ? (
    <RootLayout title={`${entry.data.title} — Lekha`} description={entry.data.description}>
      <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
        <p class="mb-8 text-sm text-muted-foreground">
          <a
            href="/lekha"
            class="inline-flex items-center gap-1.5 text-primary transition-colors hover:text-primary/90 hover:underline"
          >
            <span aria-hidden="true" class="select-none">
              ←
            </span>
            All posts
          </a>
        </p>
        <header class="mb-10 border-b border-border pb-8">
          {/* <p class="text-sm font-medium tracking-wide text-primary uppercase">Lekha</p> */}
          <h1 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
            {entry.data.title}
          </h1>
          {entry.data.description && (
            <p class="mt-4 text-lg text-muted-foreground">{entry.data.description}</p>
          )}
          <div class="mt-4 flex flex-col gap-6 sm:flex-row sm:flex-wrap sm:items-end sm:justify-between">
            <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted-foreground">
              <time datetime={entry.data.published_at?.toISOString() ?? ''}>
                {entry.data.published_at?.toLocaleDateString('en-IN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                }) ?? ''}
              </time>
            </div>
            <MainTextScriptSelector client:load initial_script_id={selected_script_id} />
          </div>
        </header>
        <div
          data-lekha-markdown
          class={`lekha-markdown ${lekha_body_font_class} prose max-w-none prose-neutral dark:prose-invert prose-headings:font-semibold prose-headings:text-foreground prose-a:text-primary`}
        >
          <Content />
        </div>
        <LekhaCodeBlockCopy client:load />
        <p class="mt-12 text-sm text-muted-foreground">
          <a
            href="/lekha"
            class="inline-flex items-center gap-1.5 text-primary transition-colors hover:text-primary/90 hover:underline"
          >
            <span aria-hidden="true" class="select-none">
              ←
            </span>
            All posts
          </a>
        </p>
      </article>
    </RootLayout>
  ) : (
    <NotFoundPage />
  )
}
